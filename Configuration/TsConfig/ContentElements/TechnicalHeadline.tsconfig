mod.wizards.newContentElement.wizardItems {
  styleguide {
    header = LLL:EXT:typo3_styleguide/Resources/Private/Language/locallang.xlf:wizard.tab.styleguide
    elements {
      typo3styleguide_technicalheadline {
        iconIdentifier = content-styleguide-headline
        title = LLL:EXT:typo3_styleguide/Resources/Private/Language/locallang.xlf:contentelement.technical_headline.label
        description = LLL:EXT:typo3_styleguide/Resources/Private/Language/locallang.xlf:contentelement.technical_headline.description
        tt_content_defValues {
          CType = typo3styleguide_technicalheadline
        }
      }
    }
    show := addToList(typo3styleguide_technicalheadline)
  }
}
