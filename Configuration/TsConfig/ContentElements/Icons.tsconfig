mod.wizards.newContentElement.wizardItems {
  styleguide {
    elements {
      typo3styleguide_icons {
        iconIdentifier = content-styleguide-icons
        title = LLL:EXT:typo3_styleguide/Resources/Private/Language/locallang.xlf:contentelement.icons.label
        description = LLL:EXT:typo3_styleguide/Resources/Private/Language/locallang.xlf:contentelement.icons.description
        tt_content_defValues {
          CType = typo3styleguide_icons
        }
      }
    }
    show := addToList(typo3styleguide_icons)
  }
}
